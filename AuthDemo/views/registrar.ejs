<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Registrar utilizador</title>
</head>
<body>
    <h1>Registre-se</h1>

    <form action="/registrar" method="post">
        <section>
            <label for="utilizador">Insira o seu utilizador: </label>
            <input type="text" name="utilizador" id="utilizador" required>
        </section>
        <section>
            <label for="pass">Insira a sua palavra-passe</label>
            <input type="password" name="pass" id="pass" required>
        </section>
        <button>Registrar</button>
    </form>
</body>
</html>