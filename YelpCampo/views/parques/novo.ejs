<% layout("layouts/boilerplate") %>

    <div class="row">
        <h1 class="text-center mb-3">Novo Parque</h1>
        <div class="col-6 offset-3">
            <form action="/parques" method="post" novalidate class="validar mb-3">
                <section class="mb-3">
                    <label for="título" class="form-label">Nome do parque: </label>
                    <input type="text" name="título" id="título" class="form-control" required>
                    <div class="valid-feedback">
                        Está Ok!
                    </div>
                    <div class="invalid-feedback">
                        Tem de inserir um nome.
                    </div>
                </section>
                <section class="mb-3">
                    <label for="preço" class="form-label me-1">Preço diário: </label>
                    <div class="input-group">
                        <input type="number" name="preço" id="preço" placeholder="0.00" class="form-control" required>
                        <span class="input-group-text">€</span>
                    </div>
                     <div class="valid-feedback">
                            Perfeito!
                        </div>
                        <div class="invalid-feedback">
                            Tem de inserir um preço diário.
                        </div>
                </section>
                <section class="mb-3">
                    <label for="localização" class="form-label">Localização: </label>
                    <input type="text" name="localização" id="localização" class="form-control" required>
                    <div class="valid-feedback">
                        Certo!
                    </div>
                    <div class="invalid-feedback">
                        Qual a localização?
                    </div>
                </section>
                <section class="mb-3">
                    <label for="descrição" class="form-label">Insira uma descrição do parque:</label>
                    <br>
                    <textarea name="descrição" id="descrição" cols="50" rows="10" class="form-control"
                        required></textarea>
                    <div class="valid-feedback">
                        Muito bem.
                    </div>
                    <div class="invalid-feedback">
                        Lamento, mas tem de inserir uma descrição...
                    </div>
                </section>
                <section class="mb-3">
                    <label for="imagem" class="form-label">Insira um URL de uma imagem do parque:</label>
                    <input type="text" name="imagem" id="imagem" cols="50" rows="10" class="form-control" required>
                    <div class="valid-feedback">
                        Obrigado.
                    </div>
                    <div class="invalid-feedback">
                        É importante inserir uma imagem.
                    </div>
                </section>
                <button class="btn btn-primary me-3">Criar</button><a href="/parques"
                    class="btn btn-danger">Cancelar</a>
            </form>
        </div>
    </div>
    </div>

