<% layout("layouts/boilerplate") %>
<div class="row justify-content-center">
        <div class="col-md-8 offset-md-2">
                <section class="card p-2 text-center mb-3">
                        <img src="<%=parque.imagem%>" alt="imagem do parque" class="img-fluid card-img-top">
                        <div class="card-body">
                                <h5 class="card-title mt-2"><%= parque.título %></h5>
                                <p class="card-text"><%= parque.descrição %></p>
                        </div>
                        <ul class="list-group list-group-flush">
                                <li class="list-group-item"><%= parque.localização %></li>
                                <li class="list-group-item"><%= parque.preço %>€/noite</li>
                        </ul>

                        <section class="card-body">
                                        <a href="/parques/<%=parque._id%>/editar"
                                                class="btn btn-info card-link">Editar</a>
                                        <form action="/parques/<%=parque._id%>?_method=DELETE" method="post" class="d-inline">
                                                <button class="btn btn-danger my-3">Apagar</button>

                                        </form>
                                <a href="/parques" class="btn btn-secondary card-link">Lista dos parques</a>
                        </section>
                </section>

        </div>
</div>
</div>